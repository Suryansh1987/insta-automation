# Neon DB - copy from your Neon dashboard
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/instasaas?sslmode=require

# Clerk - https://dashboard.clerk.com -> API Keys
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

PORT=3001
NODE_ENV=development

# Razorpay Subscriptions
# Webhook URL should point to: https://your-api-domain.com/plans/webhook
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
RAZORPAY_PLAN_ID_PRO=plan_xxxxxxxxxxxxx_pro
RAZORPAY_PLAN_ID_MAX=plan_xxxxxxxxxxxxx_max
# For monthly plans this default is effectively "up to 100 years".
RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=1200

# Azure OpenAI - optional, enables AI-personalized messages
# Leave blank to use default messages only
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2025-03-01-preview
