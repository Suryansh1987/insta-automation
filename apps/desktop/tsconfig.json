{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
     "types": ["node"],
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
        "types": ["vite/client"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@insta-saas/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src"]
}
