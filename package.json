{
  "name": "insta-saas",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "server",
    "apps/*"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev:worker": "npm run dev --workspace=apps/worker",
    "build:all": "npm run build --workspaces --if-present",
    "dist:desktop:win": "npm run build --workspace=apps/worker && npm run dist:win --workspace=apps/desktop",
    "db:migrate": "npm run migrate --workspace=server",
    "db:studio": "npm run studio --workspace=server"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.8.0"
  }
}
